# Sarvam AI API key — get one at https://dashboard.sarvam.ai
# Copy this file to .env.local and fill in your key. NEVER commit .env.local.
SARVAM_API_KEY=your_sarvam_api_key_here

# Neon/Postgres. Use the pooled URL for normal app traffic.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Neon Auth email OTP.
# Enable Neon Auth in the Neon dashboard and use its auth base URL.
NEON_AUTH_BASE_URL=https://your-neon-auth-host

# Minimum 32 characters. Generate with: openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET=replace_with_a_long_random_secret
