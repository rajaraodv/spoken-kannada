        {"speaker": "A", "roman": "ninne niivu maneyalliddraa ?", "english": "Were you at home yesterday ?"},
        {"speaker": "B", "roman": "illa, naanu maneyallirlilla.", "english": "No, I was not at home yesterday."},
        {"speaker": "A", "roman": "matte elliddri ?", "english": "Then, where were you ?"},
        {"speaker": "B", "roman": "naanu nan tootadallidde.", "english": "I was in my garden."},
        {"speaker": "A", "roman": "sanje varege alliddraa ?", "english": "Were you there till evening ?"},
        {"speaker": "B", "roman": "haudu, sanje varege allidde.", "english": "Yes, I was there till the evening."},
        {"speaker": "A", "roman": "nim tande elliddru ?", "english": "Where was your father ?"},
        {"speaker": "B", "roman": "avru maneyallee iddru.", "english": "He was at home."}
