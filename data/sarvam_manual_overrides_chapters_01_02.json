{
  "chapter-01:conversation-1:row-01": {
    "sarvam_kannada": "ನಮಸ್ಕಾರ",
    "sarvam_roman": "Namaskara"
  },
  "chapter-01:conversation-1:row-02": {
    "sarvam_kannada": "ನಮಸ್ಕಾರ",
    "sarvam_roman": "Namaskara"
  },
  "chapter-01:conversation-2:row-02": {
    "sarvam_kannada": "ನಾನು ಕನ್ನಡ ಮೇಷ್ಟ್ರು.",
    "sarvam_roman": "Naanu Kannada meshtru."
  },
  "chapter-01:conversation-2:row-03": {
    "sarvam_kannada": "ಇವರು ನನ್ನ ಸ್ನೇಹಿತರು.",
    "sarvam_roman": "Ivaru nanna snehitaru."
  },
  "chapter-01:conversation-2:row-06": {
    "sarvam_kannada": "ನಾನು ವೈದ್ಯ.",
    "sarvam_roman": "Naanu vaidya."
  },
  "chapter-01:conversation-2:row-12": {
    "sarvam_kannada": "ಅವರು ವೈದ್ಯರಾ?",
    "sarvam_roman": "Avaru vaidyara?"
  },
  "chapter-01:conversation-2:row-13": {
    "sarvam_kannada": "ಇಲ್ಲ, ಅವರು ವೈದ್ಯರಲ್ಲ,",
    "sarvam_roman": "Illa, avaru vaidyaralla,"
  },
  "chapter-01:conversation-2:row-14": {
    "sarvam_kannada": "ಅವರು ನರ್ಸ್.",
    "sarvam_roman": "Avaru nurse."
  },
  "chapter-01:conversation-3:row-03": {
    "sarvam_kannada": "ಅವರು ನಿಮ್ಮ ತಂದೆಯಾ?",
    "sarvam_roman": "Avaru nimma tandeya?"
  },
  "chapter-01:conversation-3:row-04": {
    "sarvam_kannada": "ಹೌದು, ಅವರು ನನ್ನ ತಂದೆ.",
    "sarvam_roman": "Howdu, avaru nanna tande."
  },
  "chapter-01:conversation-Continuation:row-05": {
    "sarvam_kannada": "ಅವರು ನನ್ನ ತಂಗಿ.",
    "sarvam_roman": "Avaru nanna tangi."
  },
  "chapter-01:conversation-Continuation:row-06": {
    "sarvam_kannada": "ಅವರ ಹೆಸರು ಏನು?",
    "sarvam_roman": "Avara hesaru enu?"
  },
  "chapter-02:conversation-1:row-01": {
    "sarvam_kannada": "ನಮಸ್ಕಾರ, ಮಿಸ್ಟರ್ ನಾಯ್ಡು.",
    "sarvam_roman": "Namaskara, Mr. Naidu."
  },
  "chapter-02:conversation-1:row-02": {
    "sarvam_kannada": "ಓಹೋ, ನಮಸ್ಕಾರ.",
    "sarvam_roman": "Oho, namaskara."
  },
  "chapter-02:conversation-1:row-03": {
    "sarvam_kannada": "ಬನ್ನಿ, ಕುಳಿತುಕೊಳ್ಳಿ.",
    "sarvam_roman": "Banni, kulitukolli."
  },
  "chapter-02:conversation-1:row-05": {
    "sarvam_kannada": "ನಮಸ್ಕಾರ, ಕುಳಿತುಕೊಳ್ಳಿ.",
    "sarvam_roman": "Namaskara, kulitukolli."
  },
  "chapter-02:conversation-1:row-06": {
    "sarvam_kannada": "ಇವರು ನಿಮ್ಮ ಸ್ನೇಹಿತರಾ?",
    "sarvam_roman": "Ivaru nimma snehitara?"
  },
  "chapter-02:conversation-1:row-07": {
    "sarvam_kannada": "ಇಲ್ಲ, ಇವರು ನನ್ನ ಅಣ್ಣ.",
    "sarvam_roman": "Illa, ivaru nanna anna."
  },
  "chapter-02:conversation-1:row-08": {
    "sarvam_kannada": "ಇವರು ವಕೀಲರಾ?",
    "sarvam_roman": "Ivaru vakeelara?"
  },
  "chapter-02:conversation-1:row-09": {
    "sarvam_kannada": "ಇಲ್ಲ, ಇವರು ಕವಿ.",
    "sarvam_roman": "Illa, ivaru kavi."
  },
  "chapter-02:conversation-2:row-01": {
    "sarvam_kannada": "ಮಿಸ್ಟರ್ ಶೇಖರ್, ನಿಮ್ಮ ಮನೆ ಯಾವುದು?",
    "sarvam_roman": "Mr. Shekhar, nimma mane yaavudu?"
  },
  "chapter-02:conversation-2:row-02": {
    "sarvam_kannada": "ಇದು ಒಂದು ಕಥೆ ಪುಸ್ತಕ.",
    "sarvam_roman": "Idu ondu kathe pustaka."
  },
  "chapter-02:conversation-2:row-03": {
    "sarvam_kannada": "ಇದು ನಿಮ್ಮ ಪುಸ್ತಕವಾ?",
    "sarvam_roman": "Idu nimma pustakava?"
  },
  "chapter-02:conversation-2:row-04": {
    "sarvam_kannada": "ಇಲ್ಲ, ಇದು ನನ್ನ ಪುಸ್ತಕ ಅಲ್ಲ.",
    "sarvam_roman": "Illa, idu nanna pustaka alla."
  },
  "chapter-02:conversation-2:row-05": {
    "sarvam_kannada": "ಅದರ ಹೆಸರು ಏನು?",
    "sarvam_roman": "Adara hesaru enu?"
  },
  "chapter-02:conversation-2:row-07": {
    "sarvam_kannada": "ಅದು ಕೆಟ್ಟ ಪುಸ್ತಕ.",
    "sarvam_roman": "Adu ketta pustaka."
  },
  "chapter-02:conversation-2:row-08": {
    "sarvam_kannada": "ನಿಮ್ಮ ಪುಸ್ತಕ ಯಾವುದು?",
    "sarvam_roman": "Nimma pustaka yaavudu?"
  },
  "chapter-02:conversation-2:row-09": {
    "sarvam_kannada": "ಇದು ನನ್ನ ಹೊಸ ಪುಸ್ತಕ.",
    "sarvam_roman": "Idu nanna hosa pustaka."
  },
  "chapter-02:conversation-2:row-10": {
    "sarvam_kannada": "ಇದು ತುಂಬಾ ಒಳ್ಳೆಯ ಪುಸ್ತಕ.",
    "sarvam_roman": "Idu tumba olleya pustaka."
  },
  "chapter-02:conversation-2:row-11": {
    "sarvam_kannada": "ನಿಮ್ಮ ಹೊಸ ಪುಸ್ತಕ ಯಾವುದು?",
    "sarvam_roman": "Nimma hosa pustaka yaavudu?"
  },
  "chapter-02:conversation-2:row-12": {
    "sarvam_kannada": "ಯಾವುದು? ಆ ದೊಡ್ಡ ಮನೆನಾ?",
    "sarvam_roman": "Yaavudu? Aa dodda manena?"
  },
  "chapter-02:conversation-2:row-13": {
    "sarvam_kannada": "ಅದು ತುಂಬಾ ದೊಡ್ಡ ಪುಸ್ತಕ.",
    "sarvam_roman": "Adu tumba dodda pustaka."
  },
  "chapter-02:conversation-3:row-01": {
    "sarvam_kannada": "ಇಲ್ಲ, ಚಿಕ್ಕ ಮನೆ.",
    "sarvam_roman": "Illa, chikka mane."
  },
  "chapter-02:conversation-3:row-02": {
    "sarvam_kannada": "ಅವರ ಮನೆ ಯಾವುದು?",
    "sarvam_roman": "Avara mane yaavudu?"
  },
  "chapter-02:conversation-3:row-04": {
    "sarvam_kannada": "ಅದು ತುಂಬಾ ದೊಡ್ಡ ಮನೆ.",
    "sarvam_roman": "Adu tumba dodda mane."
  }
}
